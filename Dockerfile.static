# Simple nginx container for static HTML site
FROM nginx:alpine

# Copy the HTML file to nginx html directory
COPY public-static/index.html /usr/share/nginx/html/index.html

# Configure nginx to listen on port 8080 (for Azure Container Apps)
RUN echo 'server { \
    listen 8080; \
    location / { \
        root /usr/share/nginx/html; \
        index index.html; \
    } \
}' > /etc/nginx/conf.d/default.conf

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]